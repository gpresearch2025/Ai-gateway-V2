PORT=3001
AUTH_MODE=local
TRUSTED_AUTH_USER_HEADER=x-auth-user
TRUSTED_AUTH_ORG_HEADER=x-auth-org
TRUSTED_AUTH_ROLE_HEADER=x-auth-role
DATABASE_PROVIDER=sqlite
AI_GATEWAY_DB_PATH=./data/ai-gateway.db
POSTGRES_URL=
AI_GATEWAY_ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
DEFAULT_ORG_ID=demo-org
DEFAULT_ORG_NAME=Demo Org

# External providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Local Qwen OpenAI-compatible endpoint
LOCAL_QWEN_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_QWEN_MODEL=qwen3.5-4b
LOCAL_QWEN_VLLM_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
JOB_WORKER_INTERVAL_MS=2000
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BASE_MS=2000
JOB_RETRY_MAX_MS=60000
