{
  "name": "ai-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Hybrid BYOK AI Gateway scaffold",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "capability:set": "tsx src/scripts/set-capability.ts",
    "db:migrate:postgres": "tsx src/scripts/migrate-to-postgres.ts",
    "purpose:set": "tsx src/scripts/set-purpose-policy.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "policy:set": "tsx src/scripts/set-org-policy.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "user:create": "tsx src/scripts/create-user.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.887.0",
    "@azure/identity": "^4.11.1",
    "@azure/keyvault-secrets": "^4.10.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "@types/express": "^5.0.1",
    "@types/node": "^24.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
